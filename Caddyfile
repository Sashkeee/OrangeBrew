test.orangebrew.ru {
    # Backend Auth (CRITICAL: must come before catch-all)
    handle /auth/* {
        reverse_proxy localhost:3001
    }

    # Backend API (Preserve /api prefix)
    handle /api/* {
        reverse_proxy localhost:3001
    }

    # WebSocket (Preserve /ws path)
    handle /ws {
        reverse_proxy localhost:3001
    }

    # Frontend Test (catch-all, must be last)
    handle {
        reverse_proxy localhost:8081
    }
}

www.orangebrew.ru {
    redir https://orangebrew.ru{uri}
}

orangebrew.ru {
    # Backend Auth (CRITICAL: must come before catch-all)
    handle /auth/* {
        reverse_proxy localhost:3000
    }

    # Backend API (Preserve /api prefix)
    handle /api/* {
        reverse_proxy localhost:3000
    }

    # WebSocket (Preserve /ws path)
    handle /ws {
        reverse_proxy localhost:3000
    }

    # Frontend Prod (catch-all, must be last)
    handle {
        reverse_proxy localhost:8080
    }
}
