test.orangebrew.ru {
    # Backend Auth (CRITICAL: must come before catch-all)
    handle /auth/* {
        reverse_proxy localhost:3001
    }

    # Backend API (Preserve /api prefix)
    handle /api/* {
        reverse_proxy localhost:3001
    }

    # WebSocket (Preserve /ws path)
    handle /ws {
        reverse_proxy localhost:3001
    }

    # Frontend Test (catch-all, must be last)
    handle {
        reverse_proxy localhost:8081
    }
}

www.orangebrew.ru {
    redir https://orangebrew.ru{uri}
}

orangebrew.ru {
    # Backend Auth (CRITICAL: must come before catch-all)
    handle /auth/* {
        reverse_proxy localhost:3000
    }

    # Backend API (Preserve /api prefix)
    handle /api/* {
        reverse_proxy localhost:3000
    }

    # WebSocket (Preserve /ws path)
    handle /ws {
        reverse_proxy localhost:3000
    }

    # Frontend Prod (catch-all, must be last)
    handle {
        reverse_proxy localhost:8080
    }
}

# QA CheatSheet
qacheatsheet.ru, cheatsheet.ru, qa.orangebrew.ru {
    reverse_proxy localhost:8082
}

www.qacheatsheet.ru, www.cheatsheet.ru {
    redir https://qacheatsheet.ru{uri}
}

# Messenger (Chat)
chat.orangebrew.ru, messenger.orangebrew.ru {
    # Socket.io, API, and Uploads are all on the same backend port (3002)
    handle /api/* {
        reverse_proxy localhost:3002
    }
    handle /socket.io/* {
        reverse_proxy localhost:3002
    }
    handle /uploads/* {
        reverse_proxy localhost:3002
    }
    # Frontend (8083)
    handle {
        reverse_proxy localhost:8083
    }
}
