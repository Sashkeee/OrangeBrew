# OrangeBrew Environment Configuration
# Скопируйте этот файл в .env и заполните своими данными

# Основные настройки сервера
PORT=3001
SERIAL_PORT=COM3
BAUD_RATE=115200
CONNECTION_TYPE=mock

# Безопасность
JWT_SECRET=your_super_secret_key_here
HARDWARE_API_KEY=your_hardware_api_key_here

# Telegram (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# База данных
DB_PATH=./data/orangebrew.db

#Brew-control.ru - 
Login= admin 
Pass= REMOVED_PASS

